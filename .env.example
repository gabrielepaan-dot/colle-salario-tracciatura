# Copia questo file in ".env" (nella root del progetto) e compila i valori.
# Li trovi su Firebase Console: Project Settings (icona ingranaggio) >
# General > "Your apps" > Web app > SDK setup and configuration > Config.
#
# ATTENZIONE: il file ".env" NON va mai committato (è già in .gitignore).
# Questi valori sono comunque pubblici per design (vedi firestore.rules per
# la sicurezza reale), ma teniamoli comunque fuori dal controllo versione
# per pulizia.

VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=colle-salario-tracciatura.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=colle-salario-tracciatura
VITE_FIREBASE_STORAGE_BUCKET=colle-salario-tracciatura.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:xxxxxxxxxxxxxxxxxxxxxx
