rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function autenticato() {
      return request.auth != null;
    }

    function tracciatoreIdDiUid(uid) {
      return get(/databases/$(database)/documents/tracciatoriByUid/$(uid)).data.tracciatoreId;
    }

    // Verifica SEMPRE lo stato admin "live" sul documento tracciatori
    // (mai una copia/cache), così se un admin viene rimosso o retrocesso,
    // perde i permessi immediatamente, senza bisogno di rifare login.
    function isAdmin() {
      return autenticato()
        && exists(/databases/$(database)/documents/tracciatoriByUid/$(request.auth.uid))
        && get(/databases/$(database)/documents/tracciatori/$(tracciatoreIdDiUid(request.auth.uid))).data.isAdmin == true;
    }

    // Lista tracciatori: lettura pubblica, scrittura (aggiungi/rimuovi/
    // promuovi) solo admin.
    match /tracciatori/{tracciatoreId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Collegamento device (uid anonimo) -> tracciatore scelto al login.
    // Chiunque sia autenticato può scrivere SOLO il proprio documento
    // (request.auth.uid == uid), e solo verso un tracciatore che esiste
    // davvero. Non può in nessun modo scrivere isAdmin qui: quel campo
    // non esiste in questa collezione, viene sempre letto "dal vivo"
    // dalla collezione tracciatori tramite isAdmin() sopra — impossibile
    // auto-promuoversi admin, a differenza del bug che avevamo trovato
    // nella prima versione delle policy RLS di Supabase.
    match /tracciatoriByUid/{uid} {
      allow read: if true;
      allow write: if autenticato()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['tracciatoreId'])
        && exists(/databases/$(database)/documents/tracciatori/$(request.resource.data.tracciatoreId));
    }

    // Boulder: lettura sempre pubblica. Scrittura per chiunque sia
    // autenticato (anche solo in modo anonimo) — coerente con "permessi
    // liberi tra tracciatori loggati" del requisito originale.
    match /boulder/{boulderId} {
      allow read: if true;
      allow create, update: if autenticato();
      // Cancellazione reale consentita in due soli casi:
      // 1) entro 24 ore dalla creazione (vedi src/lib/eliminaBoulder.js):
      //    oltre le 24 ore, o se manca un timestamp di creazione affidabile,
      //    l'app fa un soft-delete via update (stato: 'rimossa'), mai una
      //    delete vera;
      // 2) pulizia automatica del Cestino (vedi src/components/Cestino.jsx):
      //    un blocco già soft-eliminato da più di 7 giorni (rimossoIl) può
      //    essere eliminato per sempre.
      allow delete: if autenticato()
        && (
          (resource.data.creatoIl is timestamp
            && request.time < resource.data.creatoIl + duration.value(24, 'h'))
          || (resource.data.stato == 'rimossa'
            && resource.data.rimossoIl is timestamp
            && request.time > resource.data.rimossoIl + duration.value(7, 'd'))
        );
    }

    // Storico: lettura pubblica, scrittura/correzione per chiunque sia
    // autenticato (correggere/cancellare una voce errata è previsto).
    match /storico/{storicoId} {
      allow read: if true;
      allow create, update, delete: if autenticato();
    }
  }
}
