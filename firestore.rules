rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function autenticato() {
      return request.auth != null;
    }

    // Password condivisa (una sola, uguale per tutti i tracciatori) come
    // barriera reale prima della scrittura. config/authGate contiene solo
    // l'hash SHA-256 della password, non è leggibile da nessun client (solo
    // uno script Admin SDK locale può scriverlo, vedi scripts/set-shared-password.mjs)
    // e viene letto qui internamente con get(), che bypassa le regole del
    // documento target — stesso pattern già usato da isAdmin() sotto.
    //
    // Il confronto è "dal vivo" (non solo exists()): sbloccato() è vero solo
    // se l'hash salvato in unlockAttempts combacia ANCORA OGGI con l'hash
    // corrente in config/authGate. Questo chiude gratuitamente anche il
    // problema "rotazione password non revoca i device": appena un admin
    // ruota la password con set-shared-password.mjs, ogni unlockAttempts
    // esistente smette istantaneamente di combaciare e passwordSbloccata()
    // torna false per tutti i device già sbloccati, senza bisogno di
    // cancellare nulla a mano né di un campo "epoch" separato.
    function passwordSbloccata() {
      return autenticato()
        && exists(/databases/$(database)/documents/unlockAttempts/$(request.auth.uid))
        && get(/databases/$(database)/documents/unlockAttempts/$(request.auth.uid)).data.passwordHash
             == get(/databases/$(database)/documents/config/authGate).data.passwordHash;
    }

    match /config/authGate {
      allow read, write: if false;
    }

    // Rate limiting letto direttamente da unlockAttempts/{uid} (vedi sotto):
    // dopo 5 tentativi falliti consecutivi il device resta bloccato 15
    // minuti dall'ultimo tentativo. .get(campo, default) resta come
    // protezione difensiva contro un documento senza il campo "tentativi".
    function bloccatoPerRateLimit(uid) {
      return exists(/databases/$(database)/documents/unlockAttempts/$(uid))
        && get(/databases/$(database)/documents/unlockAttempts/$(uid)).data.get('tentativi', 0) >= 5
        && request.time < get(/databases/$(database)/documents/unlockAttempts/$(uid)).data.ts
             + duration.value(15, 'm');
    }

    // unlockAttempts/{uid} è l'unico documento che registra sia il tentativo
    // di sblocco sia il conteggio dei fallimenti. Il punto è che "tentare un
    // hash" e "far avanzare il contatore" sono la STESSA scrittura: le Rules
    // accettano solo due forme —
    //  (a) hash corretto -> tentativi torna a 0 (sblocco riuscito)
    //  (b) hash sbagliato -> tentativi DEVE avanzare esattamente di 1
    //      (o ripartire da 1 se la finestra di blocco precedente è scaduta),
    //      stessa aritmetica anti-manomissione di prima: niente reset o
    //      decrementi a piacere del client.
    // Non esiste un modo di scrivere un "tentativo" senza che Firestore
    // stesso lo conteggi, indipendentemente da cosa fa il client (bypassando
    // l'app e usando l'SDK direttamente, come nel buco originale).
    match /unlockAttempts/{uid} {
      // Lettura permessa solo al proprietario: serve a "Ricordami" (evitare
      // di richiedere la password ad ogni apertura app sullo stesso
      // device). Non apre nessuna via di accesso nuova a estranei: un
      // tracciatore già sbloccato conosce comunque già la password in
      // chiaro e potrebbe condividerla a voce con chiunque.
      allow read: if autenticato() && request.auth.uid == uid;

      allow create, update: if autenticato()
        && request.auth.uid == uid
        && !bloccatoPerRateLimit(uid)
        && request.resource.data.keys().hasOnly(['passwordHash', 'ts', 'tentativi'])
        && request.resource.data.ts == request.time
        && (
          (
            request.resource.data.passwordHash
              == get(/databases/$(database)/documents/config/authGate).data.passwordHash
            && request.resource.data.tentativi == 0
          )
          || (
            request.resource.data.passwordHash
              != get(/databases/$(database)/documents/config/authGate).data.passwordHash
            && (
              (
                !exists(/databases/$(database)/documents/unlockAttempts/$(uid))
                && request.resource.data.tentativi == 1
              )
              || (
                exists(/databases/$(database)/documents/unlockAttempts/$(uid))
                && request.resource.data.tentativi
                     == resource.data.get('tentativi', 0) + 1
              )
              || (
                exists(/databases/$(database)/documents/unlockAttempts/$(uid))
                && resource.data.get('tentativi', 0) >= 5
                && request.time > resource.data.ts + duration.value(15, 'm')
                && request.resource.data.tentativi == 1
              )
            )
          )
        );
    }

    function tracciatoreIdDiUid(uid) {
      return get(/databases/$(database)/documents/tracciatoriByUid/$(uid)).data.tracciatoreId;
    }

    // Verifica SEMPRE lo stato admin "live" sul documento tracciatori
    // (mai una copia/cache), così se un admin viene rimosso o retrocesso,
    // perde i permessi immediatamente, senza bisogno di rifare login.
    function isAdmin() {
      return autenticato()
        && exists(/databases/$(database)/documents/tracciatoriByUid/$(request.auth.uid))
        && get(/databases/$(database)/documents/tracciatori/$(tracciatoreIdDiUid(request.auth.uid))).data.isAdmin == true;
    }

    // Lista tracciatori: lettura pubblica, scrittura (aggiungi/rimuovi/
    // promuovi) solo admin.
    match /tracciatori/{tracciatoreId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Collegamento device (uid anonimo) -> tracciatore scelto al login.
    // Chiunque sia autenticato E abbia già superato il gate della password
    // condivisa (passwordSbloccata()) può scrivere SOLO il proprio
    // documento (request.auth.uid == uid), e solo verso un tracciatore che
    // esiste davvero. Non può in nessun modo scrivere isAdmin qui: quel
    // campo non esiste in questa collezione, viene sempre letto "dal vivo"
    // dalla collezione tracciatori tramite isAdmin() sopra — impossibile
    // auto-promuoversi admin, a differenza del bug che avevamo trovato
    // nella prima versione delle policy RLS di Supabase.
    match /tracciatoriByUid/{uid} {
      allow read: if true;
      allow write: if autenticato()
        && request.auth.uid == uid
        && passwordSbloccata()
        && request.resource.data.keys().hasOnly(['tracciatoreId'])
        && exists(/databases/$(database)/documents/tracciatori/$(request.resource.data.tracciatoreId));
    }

    // Boulder: lettura sempre pubblica. Scrittura solo dopo aver superato
    // il gate della password condivisa (passwordSbloccata()) — coerente
    // con "permessi liberi tra tracciatori loggati" del requisito
    // originale, ma solo per chi ha davvero dimostrato di conoscere la
    // password, non per qualunque sessione anonima.
    match /boulder/{boulderId} {
      allow read: if true;
      allow create: if passwordSbloccata();
      // Update libero per chi ha superato il gate password, TRANNE sui
      // blocchi già nel sotto-cestino (inSottocestino: true, vedi
      // src/components/SottoCestino.jsx): una volta lì, solo un admin può
      // ancora toccarli (es. "Ripristina"), coerente col fatto che la
      // pagina è visibile solo agli admin.
      allow update: if passwordSbloccata()
        && (resource.data.get('inSottocestino', false) != true || isAdmin());
      // Hard delete consentito solo su blocchi già passati dal Cestino
      // (stato: 'rimossa'). Se NON ancora nel sotto-cestino: la pulizia
      // automatica dei 7gg del Cestino normale (Cestino.jsx) resta aperta
      // a chiunque abbia superato il gate password. Una volta
      // inSottocestino: true: solo admin ("Elimina per sempre" manuale o
      // pulizia 7gg del sotto-cestino, SottoCestino.jsx).
      allow delete: if passwordSbloccata() && resource.data.stato == 'rimossa'
        && (resource.data.get('inSottocestino', false) != true || isAdmin());
    }

    // Storico: lettura pubblica, scrittura/correzione solo dopo il gate
    // della password condivisa (correggere una voce errata è previsto, ma
    // solo per chi ha dimostrato di conoscere la password).
    //
    // eseguitoDaUid (chi ha fisicamente inserito il dato) deve SEMPRE
    // combaciare con request.auth.uid: a differenza di tracciatoreId/
    // tracciatoreNome (a chi si attribuisce il merito del blocco, libero di
    // essere un altro tracciatore per design, vedi BoulderForm.jsx), questo
    // campo registra l'identità reale di chi scrive e non deve essere
    // falsificabile lato client scegliendo un altro stato React.
    match /storico/{storicoId} {
      allow read: if true;
      allow create, update: if passwordSbloccata()
        && request.resource.data.eseguitoDaUid == request.auth.uid;
      // La cancellazione di voci storico avviene solo insieme all'hard
      // delete di un boulder dal sotto-cestino (SottoCestino.jsx), azione
      // riservata agli admin: vedi allow delete su /boulder sopra.
      allow delete: if isAdmin();
    }
  }
}
