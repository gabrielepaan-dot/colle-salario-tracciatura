rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function autenticato() {
      return request.auth != null;
    }

    // Password condivisa (una sola, uguale per tutti i tracciatori) come
    // barriera reale prima della scrittura. config/authGate contiene solo
    // l'hash SHA-256 della password, non è leggibile da nessun client (solo
    // uno script Admin SDK locale può scriverlo, vedi scripts/set-shared-password.mjs)
    // e viene letto qui internamente con get(), che bypassa le regole del
    // documento target — stesso pattern già usato da isAdmin() sotto.
    // unlockAttempts/{uid} è la "prova" che quel device conosce la password:
    // il client hasha la password digitata e prova a scrivere questo
    // documento; l'hash sbagliato fa fallire la regola (nessuna scrittura,
    // nessun accesso). Una volta creato, resta valido finché l'uid anonimo
    // non cambia (cioè finché non si fa logout, vedi useAuth.js).
    function passwordSbloccata() {
      return autenticato()
        && exists(/databases/$(database)/documents/unlockAttempts/$(request.auth.uid));
    }

    match /config/authGate {
      allow read, write: if false;
    }

    function bloccatoPerRateLimit(uid) {
      return exists(/databases/$(database)/documents/loginAttempts/$(uid))
        && get(/databases/$(database)/documents/loginAttempts/$(uid)).data.count >= 5
        && request.time < get(/databases/$(database)/documents/loginAttempts/$(uid)).data.ultimoFallimento
             + duration.value(15, 'm');
    }

    match /unlockAttempts/{uid} {
      // Lettura permessa solo al proprietario: serve a "Ricordami" (evitare
      // di richiedere la password ad ogni apertura app sullo stesso
      // device). Non apre nessuna via di accesso nuova a estranei: un
      // tracciatore già sbloccato conosce comunque già la password in
      // chiaro e potrebbe condividerla a voce con chiunque.
      allow read: if autenticato() && request.auth.uid == uid;
      allow create, update: if autenticato()
        && request.auth.uid == uid
        && !bloccatoPerRateLimit(uid)
        && request.resource.data.keys().hasOnly(['passwordHash', 'ts'])
        && request.resource.data.passwordHash == get(/databases/$(database)/documents/config/authGate).data.passwordHash;
    }

    // Rate limiting sul gate password: dopo 5 fallimenti consecutivi il
    // device resta bloccato 15 minuti dall'ultimo fallimento. La finestra
    // riparte da sola col tempo (bloccatoPerRateLimit() sopra ricalcola ogni
    // volta confrontando request.time, l'orologio server, col timestamp
    // server dell'ultimo fallimento — nessuna scrittura necessaria per
    // "sbloccarsi").
    //
    // Anti-reset: un client non può abbassare count o riazzerare la
    // finestra a piacimento per aggirare il blocco. Le uniche scritture
    // permesse sono:
    //  - create: solo count == 1 (primo fallimento in assoluto per l'uid)
    //  - update: count == count_esistente + 1 (fallimento consecutivo),
    //    OPPURE count == 1 se la finestra di blocco precedente (count >= 5
    //    da oltre 15 minuti, verificato su request.time / dato server, non
    //    su un valore che il client può falsificare) è scaduta davvero.
    // Il reset a buon fine (delete) è permesso solo a chi ha appena
    // dimostrato di conoscere la password (passwordSbloccata(), che a sua
    // volta richiede l'hash corretto su unlockAttempts) — così il reset del
    // contatore non diventa esso stesso un modo per aggirare il blocco.
    // Limite noto e accettato: un logout + nuovo uid anonimo ottiene un
    // loginAttempts pulito da zero; non risolvibile solo con le Rules.
    match /loginAttempts/{uid} {
      allow read: if autenticato() && request.auth.uid == uid;

      allow create: if autenticato()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['count', 'ultimoFallimento'])
        && request.resource.data.count == 1
        && request.resource.data.ultimoFallimento == request.time;

      allow update: if autenticato()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['count', 'ultimoFallimento'])
        && request.resource.data.ultimoFallimento == request.time
        && (
          request.resource.data.count == resource.data.count + 1
          || (
            resource.data.count >= 5
            && request.time > resource.data.ultimoFallimento + duration.value(15, 'm')
            && request.resource.data.count == 1
          )
        );

      allow delete: if autenticato() && request.auth.uid == uid && passwordSbloccata();
    }

    function tracciatoreIdDiUid(uid) {
      return get(/databases/$(database)/documents/tracciatoriByUid/$(uid)).data.tracciatoreId;
    }

    // Verifica SEMPRE lo stato admin "live" sul documento tracciatori
    // (mai una copia/cache), così se un admin viene rimosso o retrocesso,
    // perde i permessi immediatamente, senza bisogno di rifare login.
    function isAdmin() {
      return autenticato()
        && exists(/databases/$(database)/documents/tracciatoriByUid/$(request.auth.uid))
        && get(/databases/$(database)/documents/tracciatori/$(tracciatoreIdDiUid(request.auth.uid))).data.isAdmin == true;
    }

    // Lista tracciatori: lettura pubblica, scrittura (aggiungi/rimuovi/
    // promuovi) solo admin.
    match /tracciatori/{tracciatoreId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Collegamento device (uid anonimo) -> tracciatore scelto al login.
    // Chiunque sia autenticato E abbia già superato il gate della password
    // condivisa (passwordSbloccata()) può scrivere SOLO il proprio
    // documento (request.auth.uid == uid), e solo verso un tracciatore che
    // esiste davvero. Non può in nessun modo scrivere isAdmin qui: quel
    // campo non esiste in questa collezione, viene sempre letto "dal vivo"
    // dalla collezione tracciatori tramite isAdmin() sopra — impossibile
    // auto-promuoversi admin, a differenza del bug che avevamo trovato
    // nella prima versione delle policy RLS di Supabase.
    match /tracciatoriByUid/{uid} {
      allow read: if true;
      allow write: if autenticato()
        && request.auth.uid == uid
        && passwordSbloccata()
        && request.resource.data.keys().hasOnly(['tracciatoreId'])
        && exists(/databases/$(database)/documents/tracciatori/$(request.resource.data.tracciatoreId));
    }

    // Boulder: lettura sempre pubblica. Scrittura solo dopo aver superato
    // il gate della password condivisa (passwordSbloccata()) — coerente
    // con "permessi liberi tra tracciatori loggati" del requisito
    // originale, ma solo per chi ha davvero dimostrato di conoscere la
    // password, non per qualunque sessione anonima.
    match /boulder/{boulderId} {
      allow read: if true;
      allow create, update: if passwordSbloccata();
      // Cancellazione reale consentita solo su blocchi già passati dal
      // Cestino (stato: 'rimossa'), sia per la pulizia automatica dopo 7
      // giorni sia per "Elimina definitivamente" manuale (vedi
      // src/components/Cestino.jsx), che può scattare anche subito dopo il
      // soft-delete se il blocco è stato in parete meno di 7 giorni.
      allow delete: if passwordSbloccata() && resource.data.stato == 'rimossa';
    }

    // Storico: lettura pubblica, scrittura/correzione solo dopo il gate
    // della password condivisa (correggere/cancellare una voce errata è
    // previsto, ma solo per chi ha dimostrato di conoscere la password).
    match /storico/{storicoId} {
      allow read: if true;
      allow create, update, delete: if passwordSbloccata();
    }
  }
}
